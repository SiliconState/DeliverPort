# Database connection string (Neon PostgreSQL recommended)
DATABASE_URL="postgresql://user:password@host:5432/deliverport?sslmode=require"

# JWT secret — generate a strong random string (min 32 chars)
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# Server port (default: 3000)
PORT=3000

# Allowed CORS origins (comma-separated)
CORS_ORIGINS="https://siliconstate.github.io,http://localhost:5500"
